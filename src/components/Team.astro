---
const { team, whatsapp } = Astro.props;
---

<section id="team" class="team-section">
  <div class="team-shell">
    <div class="team-header" data-reveal="fade">
      <div class="section-label">{team.badge}</div>
      <h2 class="section-title">{team.title}</h2>
      <p class="section-subtitle">{team.subtitle}</p>
    </div>

    <div class="team-grid">
      {team.members.map((member: any, i: number) => (
        <article class="barber-card" data-reveal style={`--d:${i * 70}ms`}>
          <div class="barber-photo">
            {member.image ? (
              <img
                src={member.image}
                alt={`${member.name}, barbero en Gent's Club`}
                width="600"
                height="750"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="barber-noimg" role="img" aria-label={`${member.name}, barbero en Gent's Club`}>
                <span>{member.name.charAt(0)}</span>
              </div>
            )}
            <span class="barber-chip">{member.role}</span>
          </div>
          <div class="barber-body">
            <h3 class="barber-name">{member.name}</h3>
            <p class="barber-specialty">{member.specialty}</p>
            <a
              class="barber-cta"
              href={`https://wa.me/${whatsapp}?text=${encodeURIComponent(`Hola, quiero agendar con ${member.name}`)}`}
              target="_blank"
              rel="noopener"
            >
              Agendar con {member.name}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team-section {
    padding: 8rem 2rem;
    background:
      radial-gradient(circle at top left, rgba(212, 175, 55, 0.08), transparent 35%),
      linear-gradient(180deg, var(--bg-primary) 0%, #0f0f0f 100%);
  }

  .team-shell { max-width: 1240px; margin: 0 auto; }

  .team-header { max-width: 680px; margin: 0 auto 3.5rem; text-align: center; }

  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label::before,
  .section-label::after {
    content: "";
    width: 25px;
    height: 1px;
    background: var(--gold);
  }

  .section-title {
    font-family: "Playfair Display", serif;
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    font-weight: 700;
    line-height: 1.12;
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .section-subtitle {
    color: var(--text-secondary);
    line-height: 1.75;
    font-size: 1rem;
    max-width: 56ch;
    margin: 0 auto;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .barber-card {
    position: relative;
    background: linear-gradient(180deg, var(--bg-card) 0%, #101010 100%);
    border: 1px solid var(--border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .barber-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-4px);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
  }

  .barber-photo {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #111;
  }

  .barber-noimg {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 50% 32%, rgba(212, 175, 55, 0.16), transparent 60%),
      linear-gradient(180deg, #1b1b1b 0%, #0e0e0e 100%);
  }

  .barber-noimg span {
    font-family: "Playfair Display", serif;
    font-size: 4.6rem;
    font-weight: 700;
    color: var(--gold);
    opacity: 0.9;
    line-height: 1;
  }

  .barber-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: saturate(0.9) contrast(1.03);
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .barber-card:hover .barber-photo img { transform: scale(1.05); }

  .barber-photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 45%, rgba(0, 0, 0, 0.7) 100%);
    pointer-events: none;
  }

  .barber-chip {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    z-index: 1;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-light);
    background: rgba(10, 10, 10, 0.55);
    border: 1px solid var(--border-hover);
    backdrop-filter: blur(8px);
    padding: 0.35rem 0.7rem;
  }

  .barber-body { padding: 1.4rem 1.4rem 1.6rem; display: grid; gap: 0.5rem; }

  .barber-name {
    font-family: "Playfair Display", serif;
    font-size: 1.5rem;
    color: var(--text-primary);
    margin: 0;
  }

  .barber-specialty {
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.55;
    font-weight: 300;
    margin: 0 0 0.6rem;
  }

  .barber-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--gold);
    text-decoration: none;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    width: fit-content;
  }

  .barber-cta svg { width: 16px; height: 16px; transition: transform 0.25s ease; }
  .barber-cta:hover { color: var(--gold-light); }
  .barber-card:hover .barber-cta svg { transform: translateX(4px); }

  /* stretched-link: toda la card es el área clickable (tap target ≥ card) */
  .barber-cta::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  @media (max-width: 900px) {
    .team-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .team-section { padding: 5rem 1.5rem; }
  }

  @media (max-width: 540px) {
    .team-grid { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .barber-card:hover { transform: none; }
    .barber-card:hover .barber-photo img { transform: none; }
  }
</style>
