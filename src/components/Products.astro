---
const { products, whatsapp } = Astro.props;
---

<section id="products" class="products-section">
  <div class="products-shell">
    <div class="products-header" data-reveal="fade">
      <div class="section-label">{products.badge}</div>
      <h2 class="section-title">{products.title}</h2>
      <p class="section-subtitle">{products.subtitle}</p>
    </div>

    <div class="products-grid">
      {products.items.map((item: any, i: number) => (
        <article class="product-card" data-reveal style={`--d:${i * 80}ms`}>
          <div class="product-photo">
            <img src={item.image} alt={item.name} width="800" height="600" loading="lazy" decoding="async" />
          </div>
          <div class="product-body">
            <h3 class="product-name">{item.name}</h3>
            <p class="product-desc">{item.description}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="products-footer" data-reveal="fade">
      {products.note && <p class="products-note">{products.note}</p>}
      <a
        class="btn-gold"
        href={`https://wa.me/${whatsapp}?text=${encodeURIComponent("Hola, quiero info sobre los productos de Gent's Club")}`}
        target="_blank"
        rel="noopener"
      >
        Preguntar disponibilidad
      </a>
    </div>
  </div>
</section>

<style>
  .products-section {
    padding: 8rem 2rem;
    background: linear-gradient(180deg, var(--bg-primary) 0%, #0f0f0f 100%);
  }

  .products-shell { max-width: 1200px; margin: 0 auto; }

  .products-header { max-width: 660px; margin: 0 auto 3rem; text-align: center; }

  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label::before,
  .section-label::after {
    content: "";
    width: 25px;
    height: 1px;
    background: var(--gold);
  }

  .section-title {
    font-family: "Playfair Display", serif;
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    font-weight: 700;
    line-height: 1.12;
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .section-subtitle {
    color: var(--text-secondary);
    line-height: 1.75;
    font-size: 1rem;
    max-width: 54ch;
    margin: 0 auto;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .product-card {
    background: linear-gradient(180deg, var(--bg-card) 0%, #101010 100%);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-4px);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
  }

  .product-photo {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #111;
  }

  .product-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.9) contrast(1.03);
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .product-card:hover .product-photo img { transform: scale(1.05); }

  .product-body { padding: 1.4rem 1.4rem 1.6rem; }

  .product-name {
    font-family: "Playfair Display", serif;
    font-size: 1.4rem;
    color: var(--gold-light);
    margin: 0 0 0.5rem;
  }

  .product-desc {
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.6;
    font-weight: 300;
    margin: 0;
  }

  .products-footer {
    margin-top: 2.75rem;
    display: grid;
    justify-items: center;
    gap: 1rem;
    text-align: center;
  }

  .products-note {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-style: italic;
    margin: 0;
  }

  .btn-gold {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 2rem;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
    color: var(--bg-primary);
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .btn-gold:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 36px rgba(212, 175, 55, 0.3);
  }

  @media (max-width: 860px) {
    .products-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
  }

  @media (max-width: 768px) {
    .products-section { padding: 5rem 1.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card:hover { transform: none; }
    .product-card:hover .product-photo img { transform: none; }
    .btn-gold:hover { transform: none; }
  }
</style>
