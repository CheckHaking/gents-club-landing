---
const { business } = Astro.props;
---

<section id="hero" class="hero-section">
  <div class="hero-noise"></div>
  <div class="hero-glow"></div>
  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="hero-eyebrow-line"></span>
      <span>{business.subtitle?.toUpperCase() || 'BARBERÍA Y PELUQUERÍA'} &bull; DESDE 2011</span>
      <span class="hero-eyebrow-line"></span>
    </div>
    <h1 class="hero-title">
      <span class="title-line">GENT'S</span>
      <span class="title-line title-accent">CLUB</span>
    </h1>
    <p class="hero-tagline">{business.heroTagline}</p>
    <div class="hero-ornament">
      <span class="ornament-line"></span>
      <span class="ornament-diamond"></span>
      <span class="ornament-line"></span>
    </div>
    <p class="hero-description">{business.heroDescription}</p>
    <div class="hero-buttons">
      <a href="#services" class="btn-gold">
        Ver Servicios
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href={`https://wa.me/${business.whatsapp}?text=Hola,%20quiero%20agendar%20una%20cita%20en%20Gent's%20Club&utm_source=landing&utm_medium=hero&utm_campaign=gentsclub`} class="btn-outline" target="_blank" rel="noopener">Agendar por WhatsApp</a>
    </div>
  </div>
  <div class="hero-scroll">
    <span class="scroll-line"></span>
    <span>Scroll</span>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(135deg, #0A0A0A 0%, #141414 50%, #0A0A0A 100%);
  }

  .hero-noise {
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.06) 0%, transparent 70%);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .hero-content {
    position: relative; z-index: 2;
    text-align: center;
    max-width: 850px;
    padding: 2rem;
    animation: heroFadeIn 1s ease-out;
  }

  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.3s forwards;
  }

  .hero-eyebrow-line {
    width: 50px; height: 1px;
    background: linear-gradient(90deg, transparent, #d4af37);
  }

  .hero-eyebrow-line:last-child {
    background: linear-gradient(90deg, #d4af37, transparent);
  }

  .hero-eyebrow span {
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    color: #d4af37;
    font-weight: 500;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(4.5rem, 13vw, 9rem);
    font-weight: 900;
    line-height: 0.85;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .title-line {
    display: block;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .title-line:nth-child(2) { animation-delay: 0.15s; }

  .title-accent {
    background: linear-gradient(135deg, #d4af37 0%, #f4e5c3 50%, #d4af37 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    font-weight: 300;
    color: #FAEBD7;
    font-style: italic;
    margin: 1.75rem 0 2rem;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.4s forwards;
  }

  .hero-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.5s forwards;
  }

  .ornament-line {
    width: 80px; height: 1px;
    background: linear-gradient(90deg, transparent, #d4af37, transparent);
  }

  .ornament-diamond {
    width: 8px; height: 8px;
    background: #d4af37;
    transform: rotate(45deg);
  }

  .hero-description {
    font-size: 1rem;
    color: #B0B0B0;
    max-width: 480px;
    margin: 0 auto 3rem;
    font-weight: 300;
    line-height: 1.8;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.6s forwards;
  }

  .hero-buttons {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.7s forwards;
  }

  .btn-gold {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.1rem 2.5rem;
    background: linear-gradient(135deg, #d4af37 0%, #f4e5c3 100%);
    color: #0A0A0A;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: all 0.4s;
    box-shadow: 0 4px 25px rgba(212, 175, 55, 0.3);
  }

  .btn-gold:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 40px rgba(212, 175, 55, 0.45);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.1rem 2.5rem;
    background: transparent;
    color: #d4af37;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: 1px solid rgba(212, 175, 55, 0.35);
    transition: all 0.4s;
  }

  .btn-outline:hover {
    background: rgba(212, 175, 55, 0.08);
    border-color: #d4af37;
    transform: translateY(-3px);
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column;
    align-items: center; gap: 0.75rem;
    z-index: 2;
    opacity: 0;
    animation: fadeIn 0.8s ease-out 1s forwards;
  }

  @keyframes fadeIn { to { opacity: 1; } }

  .scroll-line {
    width: 1px; height: 50px;
    background: linear-gradient(180deg, #d4af37, transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  .hero-scroll span:last-child {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: #d4af37;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .hero-content { padding: 1rem; }
    .hero-title { font-size: clamp(3.5rem, 18vw, 5rem); }
    .hero-eyebrow { gap: 0.75rem; margin-bottom: 2rem; }
    .hero-eyebrow span { letter-spacing: 0.25em; font-size: 0.62rem; }
    .hero-eyebrow-line { width: 28px; }
    .ornament-line { width: 50px; }
    .hero-buttons { flex-direction: column; align-items: center; width: 100%; padding: 0 1rem; }
    .btn-gold, .btn-outline { width: 100%; max-width: 300px; justify-content: center; padding: 1rem 1.5rem; font-size: 0.75rem; }
    .hero-description { font-size: 0.9rem; padding: 0 0.5rem; }
    .hero-scroll { bottom: 1.5rem; }
  }
</style>
