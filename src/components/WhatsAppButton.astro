---
const { whatsapp } = Astro.props;
const prefilled = encodeURIComponent("Hola, quiero agendar una cita en Gent's Club.");
---

<a
  href={`https://wa.me/${whatsapp}?text=${prefilled}&utm_source=landing&utm_medium=float&utm_campaign=gentsclub`}
  class="wa-float"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Agendar por WhatsApp con Gent's Club"
  data-hidden-in-hero
>
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  <span class="wa-text">Agendar</span>
</a>

<script>
  const waFloat = document.querySelector('.wa-float');
  if (waFloat) {
    const updateVisibility = () => {
      const pastHero = window.scrollY > window.innerHeight * 0.85;
      waFloat.classList.toggle('wa-visible', pastHero);
    };
    updateVisibility();
    window.addEventListener('scroll', updateVisibility, { passive: true });
    window.addEventListener('resize', updateVisibility);
  }
</script>

<style>
  .wa-float {
    position: fixed;
    bottom: 2rem; right: 2rem;
    z-index: 1000;
    display: flex; align-items: center; gap: 0.75rem;
    padding: 1rem 1.75rem;
    background: linear-gradient(135deg, #25D366, #128C7E);
    color: #fff; text-decoration: none;
    border-radius: 50px;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
    font-size: 0.9rem; font-weight: 600;
    opacity: 0;
    transform: translateY(80px);
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s ease, box-shadow 0.3s ease;
  }

  .wa-float.wa-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    animation: waPulse 1.6s ease-out 0.4s 1;
  }

  @keyframes waPulse {
    0% { box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4), 0 0 0 0 rgba(37, 211, 102, 0.55); }
    100% { box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4), 0 0 0 18px rgba(37, 211, 102, 0); }
  }

  .wa-float:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 22px rgba(37, 211, 102, 0.42);
  }

  .wa-float svg { width: 24px; height: 24px; }

  @media (max-width: 768px) {
    .wa-float { bottom: 1.5rem; right: 1.5rem; padding: 1rem; border-radius: 50%; width: 60px; height: 60px; justify-content: center; }
    .wa-text { display: none; }
    .wa-float svg { width: 28px; height: 28px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-float { transition: opacity 0.2s linear !important; animation: none !important; }
    .wa-float:hover { transform: none !important; }
  }
</style>
