---
const { booking, whatsapp, owner = "Charly" } = Astro.props;
const prefilled = encodeURIComponent("Hola, quiero agendar una cita en Gent's Club.");
const waLink = `https://wa.me/${whatsapp}?text=${prefilled}&utm_source=landing&utm_medium=booking&utm_campaign=gentsclub`;
---

<section id="agendar" class="booking-section">
  <div class="booking-shell">
    <header class="booking-header">
      <div class="section-label">{booking.badge}</div>
      <h2 class="section-title">
        {booking.title} <span class="accent">{booking.titleAccent}</span>
      </h2>
      <p class="section-subtitle">{booking.subtitle}</p>
    </header>

    <div class="booking-rail-container">
      <span class="booking-rail" aria-hidden="true"></span>
      <ol class="booking-steps" aria-label="Pasos para agendar">
        {booking.steps.map((step: any, index: number) => (
          <li class="step-card" data-icon={step.icon}>
            <div class="step-bg" aria-hidden="true">
              {step.icon === "whatsapp" && (
                <svg viewBox="0 0 200 200" preserveAspectRatio="none">
                  <g fill="none" stroke="rgba(212,175,55,0.07)" stroke-width="1">
                    <path d="M0 130 L40 130 L40 145 L0 145"/>
                    <path d="M160 160 L200 160 L200 175 L160 175"/>
                    <circle cx="170" cy="135" r="3"/>
                    <circle cx="178" cy="135" r="3"/>
                    <circle cx="186" cy="135" r="3"/>
                  </g>
                </svg>
              )}
              {step.icon === "bolt" && (
                <svg viewBox="0 0 200 200" preserveAspectRatio="none">
                  <g stroke="rgba(212,175,55,0.07)" stroke-width="1" fill="none">
                    <path d="M0 130 L55 130"/>
                    <path d="M0 145 L40 145"/>
                    <path d="M0 160 L60 160"/>
                    <path d="M150 130 L200 130"/>
                    <path d="M160 145 L200 145"/>
                    <path d="M140 160 L200 160"/>
                  </g>
                </svg>
              )}
              {step.icon === "calendar" && (
                <svg viewBox="0 0 200 200" preserveAspectRatio="none">
                  <g fill="rgba(212,175,55,0.08)">
                    <rect x="20" y="135" width="22" height="2"/>
                    <rect x="20" y="148" width="34" height="2"/>
                    <rect x="20" y="161" width="18" height="2"/>
                    <rect x="160" y="135" width="22" height="2"/>
                    <rect x="160" y="148" width="14" height="2"/>
                    <rect x="160" y="161" width="28" height="2"/>
                  </g>
                </svg>
              )}
              {step.icon === "check" && (
                <svg viewBox="0 0 200 200" preserveAspectRatio="none">
                  <g fill="rgba(212,175,55,0.09)">
                    <circle cx="30" cy="140" r="2"/>
                    <circle cx="42" cy="155" r="2.5"/>
                    <circle cx="58" cy="138" r="1.5"/>
                    <circle cx="160" cy="160" r="2"/>
                    <circle cx="172" cy="142" r="2.5"/>
                    <circle cx="184" cy="155" r="1.5"/>
                  </g>
                  <g fill="none" stroke="rgba(212,175,55,0.07)" stroke-width="1" stroke-linecap="round">
                    <path d="M22 145 l4 4 l8 -10"/>
                    <path d="M170 152 l4 4 l8 -10"/>
                  </g>
                </svg>
              )}
            </div>

            <div class="step-icon-wrap">
              <span class="step-badge">{String(index + 1).padStart(2, "0")}</span>
              <div class="step-icon" aria-hidden="true">
                {step.icon === "whatsapp" && (
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
                    <path d="M9 24a15 15 0 1 1 5.6 11.7L7 38l2.4-7.4A14.9 14.9 0 0 1 9 24Z"/>
                    <path d="M19.5 18.5c-.4 0-.9 0-1.2.4-.5.6-1.7 1.6-1.7 4 0 2.3 1.7 4.6 2 4.9.2.3 3.4 5.2 8.2 7 4 1.6 4.8 1.3 5.7 1.2 1-.1 2.8-1.2 3.3-2.3.3-1.1.3-2 .2-2.2-.1-.2-.4-.3-.9-.5-.5-.3-2.8-1.4-3.3-1.6-.4-.2-.7-.2-1 .2-.3.5-1.2 1.6-1.5 1.9-.3.3-.5.4-1 .1-2.8-1.4-4.7-2.5-6.5-5.7-.5-.8.5-.8 1.4-2.5.2-.3.1-.6 0-.8-.1-.2-1-2.4-1.4-3.3-.3-.8-.6-.7-.9-.7Z"/>
                    <circle cx="40" cy="12" r="2.5" fill="currentColor" opacity="0.9" stroke="none"/>
                    <circle cx="44" cy="20" r="1.4" fill="currentColor" opacity="0.6" stroke="none"/>
                  </svg>
                )}
                {step.icon === "bolt" && (
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
                    <path d="M10 35c-2-2-3-4.7-3-7.5C7 21 12 16 19 16h10c6 0 11 5 11 11s-5 11-11 11h-9c-1.2 0-2.4.4-3.4 1.1L13 41l1.5-4.5c.1-.4.1-.9-.1-1.3"/>
                    <path d="M26 21 21 28h5l-2 6 7-8h-5Z" fill="currentColor" opacity="0.9" stroke="none"/>
                    <path d="M40 12l-2 3M42 8l2 1M40 22l3-1" stroke-width="1.4"/>
                  </svg>
                )}
                {step.icon === "calendar" && (
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
                    <rect x="7" y="10" width="34" height="31" rx="3"/>
                    <path d="M7 19h34"/>
                    <path d="M15 6v6M33 6v6"/>
                    <circle cx="24" cy="28" r="3.5" fill="currentColor" opacity="0.9" stroke="none"/>
                    <circle cx="14" cy="28" r="1.3" fill="currentColor" opacity="0.45" stroke="none"/>
                    <circle cx="34" cy="28" r="1.3" fill="currentColor" opacity="0.45" stroke="none"/>
                    <circle cx="14" cy="35" r="1.3" fill="currentColor" opacity="0.45" stroke="none"/>
                    <circle cx="24" cy="35" r="1.3" fill="currentColor" opacity="0.45" stroke="none"/>
                    <circle cx="34" cy="35" r="1.3" fill="currentColor" opacity="0.45" stroke="none"/>
                  </svg>
                )}
                {step.icon === "check" && (
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
                    <circle cx="24" cy="24" r="14"/>
                    <path d="m17 25 5 5 10-11"/>
                    <path d="M40 14l-2 2M8 14l2 2M40 34l-2-2M8 34l2-2" stroke-width="1.5"/>
                    <circle cx="42" cy="24" r="1.2" fill="currentColor" opacity="0.7" stroke="none"/>
                    <circle cx="6" cy="24" r="1.2" fill="currentColor" opacity="0.7" stroke="none"/>
                  </svg>
                )}
              </div>
            </div>

            <div class="step-body">
              <span class="step-eyebrow">{step.eyebrow}</span>
              <h3 class="step-title">{step.title}</h3>
              <p class="step-desc">{step.description}</p>
              {step.meta && (
                <div class="step-meta">
                  <svg width="11" height="11" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                    <circle cx="8" cy="8" r="6.5"/>
                    <path d="M8 4.5V8l2 2"/>
                  </svg>
                  <span>{step.meta}</span>
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>

    <aside class="booking-rules">
      <div class="rules-head">
        <span class="rules-kicker">Política de citas</span>
        <h3>{booking.rulesTitle}</h3>
      </div>
      <ul class="rules-list">
        {booking.rules.map((rule: string) => (
          <li>
            <span class="rule-dot" aria-hidden="true"></span>
            <span>{rule}</span>
          </li>
        ))}
      </ul>
      <a href={waLink} class="rules-cta" target="_blank" rel="noopener">
        Agendar por WhatsApp
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </aside>
  </div>
</section>

<style>
  /* === SECTION FRAME === */
  .booking-section {
    padding: 8rem 2rem;
    background:
      radial-gradient(circle at 15% 0%, rgba(212, 175, 55, 0.08), transparent 38%),
      radial-gradient(circle at 85% 100%, rgba(212, 175, 55, 0.05), transparent 40%),
      linear-gradient(180deg, #090909 0%, #111111 100%);
    border-top: 1px solid rgba(212, 175, 55, 0.06);
  }

  .booking-shell {
    max-width: 1280px;
    margin: 0 auto;
  }

  .booking-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 4.5rem;
  }

  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: #d4af37;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label::before,
  .section-label::after {
    content: "";
    width: 25px;
    height: 1px;
    background: #d4af37;
  }

  .section-title {
    font-family: "Playfair Display", serif;
    font-size: clamp(2.3rem, 5vw, 3.6rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .accent {
    background: linear-gradient(135deg, #d4af37, #f4e5c3);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    font-size: 1.02rem;
    color: #b0b0b0;
    line-height: 1.75;
    max-width: 56ch;
    margin: 0 auto;
    font-weight: 300;
  }

  /* === RAIL CONTAINER === */
  .booking-rail-container {
    position: relative;
    margin-bottom: 4.5rem;
  }

  /* horizontal dashed rail crossing through the icon row */
  .booking-rail {
    position: absolute;
    top: 67px; /* aligns with vertical center of 68px icon (icon-wrap top = 28px padding + 5px badge offset → ~34px to icon center) */
    left: calc(68px / 2 + 1.6rem);
    right: calc(68px / 2 + 1.6rem);
    height: 0;
    border-top: 1.5px dashed rgba(212, 175, 55, 0.45);
    z-index: 0;
    pointer-events: none;
  }

  .booking-rail::after {
    content: "";
    position: absolute;
    right: -10px;
    top: -6px;
    width: 0;
    height: 0;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-left: 9px solid #d4af37;
    filter: drop-shadow(0 0 6px rgba(212, 175, 55, 0.55));
  }

  /* === STEPS GRID === */
  .booking-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .step-card {
    position: relative;
    padding: 1.6rem 1.6rem 1.85rem;
    background: linear-gradient(180deg, #0d0d0d 0%, #0a0a0a 100%);
    border: 1px solid rgba(212, 175, 55, 0.16);
    display: grid;
    grid-template-rows: auto auto 1fr;
    gap: 1.35rem;
    overflow: hidden;
    transition: border-color 0.35s ease, transform 0.35s ease, box-shadow 0.35s ease;
  }

  .step-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.55;
    transition: opacity 0.45s ease;
  }

  .step-bg svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .step-card:hover .step-bg { opacity: 1; }

  .step-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, #d4af37, transparent);
    opacity: 0;
    transition: opacity 0.35s ease;
    z-index: 2;
  }

  .step-card:hover {
    border-color: rgba(212, 175, 55, 0.42);
    transform: translateY(-4px);
    box-shadow: 0 22px 55px rgba(0, 0, 0, 0.45), 0 0 36px rgba(212, 175, 55, 0.12);
  }

  .step-card:hover::before { opacity: 1; }

  /* === ICON BLOCK === */
  .step-icon-wrap {
    position: relative;
    width: 68px;
    height: 68px;
    z-index: 1;
    justify-self: start;
  }

  .step-icon {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    border: 1px solid rgba(212, 175, 55, 0.4);
    background: radial-gradient(circle at 30% 25%, rgba(212, 175, 55, 0.22), rgba(212, 175, 55, 0.04) 70%), #0d0d0d;
    color: #f4e5c3;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .step-icon svg {
    width: 38px;
    height: 38px;
    filter: drop-shadow(0 0 8px rgba(212, 175, 55, 0.35));
  }

  .step-card:hover .step-icon {
    transform: rotate(-4deg) scale(1.06);
    border-color: #d4af37;
    box-shadow: inset 0 0 24px rgba(212, 175, 55, 0.18);
  }

  .step-badge {
    position: absolute;
    top: -10px;
    right: -10px;
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: linear-gradient(135deg, #d4af37, #f4e5c3);
    color: #0a0a0a;
    font-family: "Playfair Display", serif;
    font-size: 0.82rem;
    font-weight: 700;
    box-shadow: 0 4px 14px rgba(212, 175, 55, 0.45);
    z-index: 3;
  }

  /* === BODY === */
  .step-body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
  }

  .step-eyebrow {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #d4af37;
    margin-bottom: 0.55rem;
  }

  .step-title {
    font-family: "Playfair Display", serif;
    font-size: 1.22rem;
    line-height: 1.3;
    color: #f4e5c3;
    margin: 0 0 0.55rem;
  }

  .step-desc {
    color: #b0b0b0;
    font-size: 0.92rem;
    line-height: 1.65;
    margin: 0 0 1.05rem;
    flex: 1;
  }

  .step-meta {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.7rem;
    background: rgba(212, 175, 55, 0.08);
    border: 1px solid rgba(212, 175, 55, 0.25);
    color: #d4af37;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .step-meta svg { color: currentColor; }

  /* === RULES BLOCK === */
  .booking-rules {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr auto;
    gap: 2.5rem;
    align-items: center;
    padding: 2.25rem 2.4rem;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.08), rgba(255, 255, 255, 0.02));
    border: 1px solid rgba(212, 175, 55, 0.2);
    position: relative;
    overflow: hidden;
  }

  .booking-rules::before {
    content: "";
    position: absolute;
    top: -40px; right: -40px;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.18), transparent 70%);
    pointer-events: none;
  }

  .rules-kicker {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #d4af37;
    margin-bottom: 0.7rem;
  }

  .rules-head h3 {
    font-family: "Playfair Display", serif;
    font-size: 1.55rem;
    line-height: 1.25;
    color: #faebd7;
    margin: 0;
  }

  .rules-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
    position: relative;
    z-index: 1;
  }

  .rules-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: 0.85rem;
    color: #dadada;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .rule-dot {
    width: 7px;
    height: 7px;
    margin-top: 0.55rem;
    background: linear-gradient(135deg, #d4af37, #f4e5c3);
    transform: rotate(45deg);
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.4);
  }

  .rules-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 1.05rem 1.65rem;
    background: linear-gradient(135deg, #d4af37 0%, #f4e5c3 100%);
    color: #0a0a0a;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    box-shadow: 0 4px 22px rgba(212, 175, 55, 0.28);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    white-space: nowrap;
    position: relative;
    z-index: 1;
  }

  .rules-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(212, 175, 55, 0.4);
  }

  /* === RESPONSIVE === */
  @media (max-width: 1024px) {
    .booking-steps { grid-template-columns: repeat(2, 1fr); }
    .booking-rail { display: none; }
    .booking-rules {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      text-align: left;
      padding: 2rem 1.75rem;
    }
    .rules-cta { justify-self: start; }
  }

  @media (max-width: 768px) {
    .booking-section { padding: 5rem 1.5rem; }
    .booking-steps { grid-template-columns: 1fr; gap: 1rem; }
    .booking-header { margin-bottom: 3rem; }
    .step-icon-wrap { width: 60px; height: 60px; }
    .step-icon svg { width: 32px; height: 32px; }
    .rules-head h3 { font-size: 1.3rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .step-card, .step-icon, .rules-cta, .step-bg { transition: none !important; }
    .step-card:hover, .rules-cta:hover { transform: none !important; }
    .step-card:hover .step-icon { transform: none !important; }
  }
</style>
