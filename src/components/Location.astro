---
const { business } = Astro.props;
---

<section id="location" class="location-section">
  <div class="location-container">
    <div class="location-info">
      <div class="info-inner">
        <div class="section-label">Visítanos</div>
        <h2 class="section-title">En el corazón <span class="accent">de Lerdo</span></h2>
        <div class="location-details">
          <div class="detail-item">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <h4>Dirección</h4>
              <p>{business.address}</p>
              <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(business.address)}`} class="detail-link" target="_blank" rel="noopener">
                Ver en Google Maps
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg>
              </a>
            </div>
          </div>
          <div class="detail-item">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <h4>Horarios</h4>
              <p>{business.weekdays}: {business.hours}</p>
              <p class="muted">Domingo: {business.sunday}</p>
            </div>
          </div>
          <div class="detail-item">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <h4>Contacto</h4>
              <p>{business.phone}</p>
              <a href={`https://wa.me/${business.whatsapp}`} class="detail-link" target="_blank" rel="noopener">WhatsApp</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="location-map">
      <div class="map-card">
        <div class="map-pin">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <p>{business.address}</p>
        <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(business.address)}`} class="btn-gold" target="_blank" rel="noopener">Abrir en Maps</a>
      </div>
    </div>
  </div>
</section>

<style>
  .location-section { background: #0f0f0f; }

  .location-container {
    display: grid; grid-template-columns: 1fr 1fr;
    max-width: 1400px; margin: 0 auto; min-height: 600px;
  }

  .location-info { padding: 6rem 4rem; display: flex; align-items: center; }
  .info-inner { max-width: 480px; }

  .section-label {
    font-size: 0.7rem; letter-spacing: 0.3em; color: #d4af37;
    text-transform: uppercase; font-weight: 500; margin-bottom: 1rem;
    display: inline-flex; align-items: center; gap: 1rem;
  }

  .section-label::before, .section-label::after {
    content: ''; width: 25px; height: 1px; background: #d4af37;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700; line-height: 1.2; margin-bottom: 3rem;
  }

  .accent {
    background: linear-gradient(135deg, #d4af37, #f4e5c3);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .location-details { display: flex; flex-direction: column; gap: 2.5rem; }

  .detail-item { display: flex; gap: 1.25rem; }

  .detail-icon {
    width: 48px; height: 48px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid rgba(212, 175, 55, 0.12); color: #d4af37;
  }

  .detail-icon svg { width: 22px; height: 22px; }

  .detail-item h4 {
    font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: #d4af37; margin-bottom: 0.35rem; font-weight: 500;
  }

  .detail-item p { font-size: 1rem; color: #fff; line-height: 1.5; }
  .muted { color: #707070 !important; font-size: 0.9rem !important; font-style: italic; }

  .detail-link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    margin-top: 0.75rem; color: #d4af37; text-decoration: none;
    font-size: 0.875rem; font-weight: 500; transition: all 0.3s;
  }

  .detail-link:hover { gap: 0.75rem; color: #f4e5c3; }

  .location-map {
    background: linear-gradient(135deg, #141414, #1a1a1a);
    display: flex; align-items: center; justify-content: center;
    position: relative;
  }

  .map-card {
    text-align: center; padding: 3rem;
    border: 1px solid rgba(212, 175, 55, 0.12);
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(12px); max-width: 350px;
  }

  .map-pin { width: 56px; height: 56px; margin: 0 auto 1.5rem; color: #d4af37; }

  .map-card p { font-size: 1rem; color: #fff; line-height: 1.6; margin-bottom: 2rem; }

  .btn-gold {
    display: inline-flex; padding: 1rem 2rem;
    background: linear-gradient(135deg, #d4af37, #f4e5c3);
    color: #0a0a0a; text-decoration: none;
    font-size: 0.8rem; font-weight: 600; letter-spacing: 0.1em;
    transition: all 0.3s; box-shadow: 0 4px 20px rgba(212, 175, 55, 0.3);
  }

  .btn-gold:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 30px rgba(212, 175, 55, 0.4);
  }

  @media (max-width: 1024px) {
    .location-container { grid-template-columns: 1fr; }
    .location-info { padding: 5rem 2rem; }
    .location-map { min-height: 400px; }
  }

  @media (max-width: 768px) {
    .location-info { padding: 4rem 1.5rem; }
    .detail-item { flex-direction: column; }
    .map-card { padding: 2rem; margin: 1rem; }
  }
</style>
