---
const { business } = Astro.props;
const prefilled = encodeURIComponent(`Hola ${business.owner}, quiero agendar una cita.`);
const waLink = `https://wa.me/${business.whatsapp}?text=${prefilled}&utm_source=landing&utm_medium=location&utm_campaign=gentsclub`;
---

<section id="location" class="closing-section">
  <div class="closing-shell">
    <div class="closing-copy">
      <div class="section-label">Cita por WhatsApp</div>
      <h2 class="closing-title">
        Tu cita empieza <span class="accent">en WhatsApp.</span>
      </h2>
      <p class="closing-sub">
        Mándale mensaje a {business.owner}, revisa horario disponible y confirma sin rodeos.
      </p>
    </div>

    <div class="closing-actions">
      <div class="hours-card" aria-label="Horario de atención">
        <div class="hours-label">Horario</div>
        <div class="hours-row">
          <span>{business.weekdays}</span>
          <span class="hours-time">{business.hours}</span>
        </div>
        <div class="hours-row muted">
          <span>Domingo</span>
          <span>{business.sunday}</span>
        </div>
      </div>

      <a href={waLink} class="btn-gold" target="_blank" rel="noopener">
        Agendar con {business.owner}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .closing-section {
    padding: 6rem 2rem;
    background:
      radial-gradient(circle at 80% 50%, rgba(212, 175, 55, 0.08), transparent 45%),
      linear-gradient(180deg, #0f0f0f 0%, #080808 100%);
    border-top: 1px solid rgba(212, 175, 55, 0.08);
  }

  .closing-shell {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 3rem;
    align-items: center;
  }

  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--gold, #d4af37);
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label::before {
    content: '';
    width: 25px;
    height: 1px;
    background: var(--gold, #d4af37);
  }

  .closing-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .accent {
    background: linear-gradient(135deg, #d4af37, #f4e5c3);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .closing-sub {
    color: #b0b0b0;
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 46ch;
  }

  .closing-actions {
    display: grid;
    gap: 1.5rem;
    justify-items: stretch;
  }

  .hours-card {
    padding: 1.4rem 1.6rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
    border: 1px solid rgba(212, 175, 55, 0.14);
  }

  .hours-label {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #d4af37;
    margin-bottom: 0.85rem;
  }

  .hours-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.45rem 0;
    font-size: 0.98rem;
    color: #f4e5c3;
  }

  .hours-row + .hours-row {
    border-top: 1px solid rgba(212, 175, 55, 0.08);
  }

  .hours-time {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
  }

  .hours-row.muted {
    color: var(--text-muted, #8A8A8A);
    font-size: 0.9rem;
  }

  .btn-gold {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.15rem 2rem;
    background: linear-gradient(135deg, #d4af37 0%, #f4e5c3 100%);
    color: #0a0a0a;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    box-shadow: 0 4px 25px rgba(212, 175, 55, 0.28);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .btn-gold:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 35px rgba(212, 175, 55, 0.4);
  }

  @media (max-width: 900px) {
    .closing-shell {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .closing-section { padding: 4.5rem 1.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-gold { transition: none; }
    .btn-gold:hover { transform: none; }
  }
</style>
