---
import { getBarbers, getBarberPhotoUrl } from '../lib/directus';
const barbers = await getBarbers();
---

{barbers.length > 0 && (
<section id="barbers" class="barbers-section">
  <div class="barbers-inner">
    <div class="barbers-header">
      <div class="section-label">El Equipo</div>
      <h2 class="section-title">Nuestros <span class="accent">Barberos</span></h2>
      <p class="section-subtitle">Profesionales con pasión por el estilo y la atención al detalle.</p>
    </div>
    <div class="barbers-grid">
      {barbers.map((barber: any) => (
        <div class="barber-card">
          <div class="barber-photo-wrap">
            <a href={`/barbero/${barber.slug}`}>
              <img
                src={getBarberPhotoUrl(barber.photo)}
                alt={barber.name}
                class="barber-photo"
                loading="lazy"
              />
            </a>
            <div class="barber-socials">
              {barber.instagram && (
                <a href={`https://instagram.com/${barber.instagram}`} class="social-icon" title="Instagram" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
              )}
              {barber.tiktok && (
                <a href={`https://tiktok.com/@${barber.tiktok}`} class="social-icon" title="TikTok" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-.81-.1l-.38.9z"/></svg>
                </a>
              )}
              {barber.facebook && (
                <a href={barber.facebook.startsWith('http') ? barber.facebook : `https://facebook.com/${barber.facebook}`} class="social-icon" title="Facebook" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              )}
            </div>
          </div>
          <div class="barber-info">
            <h3 class="barber-name">{barber.nickname || barber.name}</h3>
            {barber.specialty && <p class="barber-specialty">{barber.specialty}</p>}
            <a href={`/barbero/${barber.slug}`} class="barber-link">Ver trabajos <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<style>
  .barbers-section {
    padding: 8rem 2rem;
    background: #111111;
    position: relative;
  }

  .barbers-inner { max-width: 1200px; margin: 0 auto; }
  .barbers-header { text-align: center; margin-bottom: 5rem; }

  .section-label {
    font-size: 0.7rem; letter-spacing: 0.3em; color: #d4af37;
    text-transform: uppercase; font-weight: 500; margin-bottom: 1rem;
    display: inline-flex; align-items: center; gap: 1rem;
  }
  .section-label::before, .section-label::after {
    content: ''; width: 25px; height: 1px; background: #d4af37;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700; line-height: 1.15; margin-bottom: 1.25rem;
  }
  .accent {
    background: linear-gradient(135deg, #d4af37, #f4e5c3);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .section-subtitle {
    font-size: 1.05rem; color: #B0B0B0; max-width: 550px;
    margin: 0 auto; line-height: 1.7; font-weight: 300;
  }

  .barbers-grid {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 1rem;
    scrollbar-width: none;
  }

  .barbers-grid::-webkit-scrollbar { display: none; }

  .barber-card {
    color: inherit;
    background: #151515;
    border: 1px solid rgba(212, 175, 55, 0.2);
    overflow: hidden;
    min-width: 300px;
    max-width: 320px;
    flex-shrink: 0;
    scroll-snap-align: center;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .barber-card:hover {
    transform: translateY(-8px);
    border-color: rgba(212, 175, 55, 0.35);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(212, 175, 55, 0.1);
  }

  .barber-photo-wrap {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
  }

  .barber-photo {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .barber-card:hover .barber-photo { transform: scale(1.05); }

  .barber-socials {
    position: absolute;
    bottom: 1rem; left: 1rem;
    display: flex; gap: 0.5rem;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s;
  }

  .barber-card:hover .barber-socials {
    opacity: 1; transform: translateY(0);
  }

  .social-icon {
    width: 36px; height: 36px;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(212, 175, 55, 0.3);
    display: flex; align-items: center; justify-content: center;
    color: #d4af37;
    text-decoration: none;
    transition: all 0.3s;
  }

  .social-icon svg { width: 16px; height: 16px; }

  .social-icon:hover {
    background: #d4af37;
    color: #0a0a0a;
  }

  .social-icon:active {
    transform: scale(0.95);
  }

  .barber-info { padding: 1.5rem; }

  .barber-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem; font-weight: 700; margin-bottom: 0.25rem;
  }

  .barber-specialty {
    font-size: 0.85rem; color: #d4af37;
    font-weight: 400; margin-bottom: 0.75rem;
  }

  .barber-link {
    font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: #707070; display: flex; align-items: center; gap: 0.5rem;
    transition: all 0.3s; text-decoration: none;
  }

  .barber-link:hover { color: #d4af37; gap: 0.75rem; }

  .barber-card:hover .barber-link { color: #d4af37; gap: 0.75rem; }

  @media (max-width: 768px) {
    .barbers-section { padding: 5rem 1rem; }
    .barbers-grid { gap: 1rem; padding: 0 0.5rem; }
    .barber-card { min-width: 260px; max-width: 280px; }
    .barber-socials { opacity: 1; transform: translateY(0); }
    .barber-photo-wrap { aspect-ratio: 3/4; min-height: 250px; }
  }
</style>
