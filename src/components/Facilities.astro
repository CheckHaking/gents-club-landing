---
const { facilities, amenities = [] } = Astro.props;

const dims: Record<string, { w: number; h: number }> = {
  tall: { w: 600, h: 900 },
  wide: { w: 900, h: 450 },
  "": { w: 600, h: 450 }
};
---

<section id="facilities" class="facilities-section">
  <div class="facilities-shell">
    <div class="facilities-header" data-reveal="fade">
      <div class="section-label">{facilities.badge}</div>
      <h2 class="section-title">{facilities.title}</h2>
      <p class="section-subtitle">{facilities.subtitle}</p>
    </div>

    <div class="facilities-grid">
      {facilities.images.map((img: any, i: number) => (
        <figure class={`facility-item ${img.span}`} data-reveal style={`--d:${i * 60}ms`}>
          <img
            src={img.src}
            alt={img.alt}
            width={dims[img.span]?.w ?? 600}
            height={dims[img.span]?.h ?? 450}
            loading="lazy"
            decoding="async"
          />
          <figcaption>{img.caption}</figcaption>
        </figure>
      ))}
    </div>

    {amenities.length > 0 && (
      <ul class="amenities-strip" data-reveal>
        {amenities.map((item: any) => (
          <li class="amenity">
            <span class="amenity-mark" aria-hidden="true"></span>
            <div>
              <span class="amenity-title">{item.title}</span>
              <p class="amenity-desc">{item.description}</p>
            </div>
          </li>
        ))}
      </ul>
    )}

    {facilities.note && <p class="facilities-note">{facilities.note}</p>}
  </div>
</section>

<style>
  .facilities-section {
    padding: 8rem 2rem;
    background:
      radial-gradient(circle at bottom right, rgba(212, 175, 55, 0.07), transparent 35%),
      linear-gradient(180deg, #0f0f0f 0%, var(--bg-primary) 100%);
  }

  .facilities-shell { max-width: 1240px; margin: 0 auto; }

  .facilities-header { max-width: 680px; margin: 0 auto 3rem; text-align: center; }

  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label::before,
  .section-label::after {
    content: "";
    width: 25px;
    height: 1px;
    background: var(--gold);
  }

  .section-title {
    font-family: "Playfair Display", serif;
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    font-weight: 700;
    line-height: 1.12;
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .section-subtitle {
    color: var(--text-secondary);
    line-height: 1.75;
    font-size: 1rem;
    max-width: 56ch;
    margin: 0 auto;
  }

  .facilities-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 200px;
    gap: 1rem;
  }

  .facility-item {
    position: relative;
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--border);
    background: #111;
    grid-column: span 2;
    grid-row: span 1;
  }

  .facility-item.wide { grid-column: span 2; }
  .facility-item.tall { grid-row: span 2; }

  .facility-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.88) contrast(1.04) brightness(0.92);
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1), filter 0.4s ease;
  }

  .facility-item:hover img {
    transform: scale(1.06);
    filter: saturate(1) contrast(1.05) brightness(1);
  }

  .facility-item figcaption {
    position: absolute;
    left: 1rem;
    bottom: 0.9rem;
    z-index: 1;
    font-family: "Cormorant Garamond", serif;
    font-size: 1.05rem;
    color: var(--gold-light);
    letter-spacing: 0.02em;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8);
  }

  .facility-item::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 50%, rgba(0, 0, 0, 0.6) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .facility-item:hover::after { opacity: 1; }
  .facility-item:hover figcaption { opacity: 1; transform: none; }

  /* amenities (movidas desde GooglePresence para evitar redundancia) */
  .amenities-strip {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .amenity {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: 0.85rem;
    padding: 1rem 1.1rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
  }

  .amenity-mark {
    width: 9px;
    height: 9px;
    margin-top: 0.5rem;
    background: var(--gold);
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
    transform: rotate(45deg);
  }

  .amenity-title {
    font-family: "Playfair Display", serif;
    font-size: 1.05rem;
    color: var(--gold-light);
    line-height: 1.2;
  }

  .amenity-desc {
    margin: 0.3rem 0 0;
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.55;
    font-weight: 300;
  }

  .facilities-note {
    text-align: center;
    margin-top: 1.75rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    font-style: italic;
  }

  @media (max-width: 900px) {
    .facilities-grid { grid-auto-rows: 160px; }
    .amenities-strip { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .facilities-section { padding: 5rem 1.5rem; }
    .facilities-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 150px;
    }
    .facility-item, .facility-item.wide { grid-column: span 1; }
    .facility-item.tall { grid-row: span 2; }
    .facility-item figcaption { opacity: 1; transform: none; }
    .amenities-strip { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .facility-item:hover img { transform: none; }
  }
</style>
