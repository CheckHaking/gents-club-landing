---
import { getServices, getBusinessInfo } from '../lib/directus';
const services = await getServices();
const business = await getBusinessInfo();
---

<section id="services" class="services-section">
  <div class="services-inner">
    <div class="services-header">
      <div class="section-label">Nuestros Servicios</div>
      <h2 class="section-title">Maestría en <span class="accent">cada detalle</span></h2>
      <p class="section-subtitle">Servicios diseñados para el caballero moderno que valora la calidad y la atención al detalle.</p>
    </div>
    <div class="services-grid">
      {services.map((service: any, index: number) => (
        <article class="service-card" style={`animation-delay: ${index * 0.1}s`}>
          <div class="service-number">0{index + 1}</div>
          <h3 class="service-name">{service.name}</h3>
          <p class="service-desc">{service.description}</p>
          <div class="service-bottom">
            <span class="service-price">${service.price} <span class="currency">MXN</span></span>
            <a href={`https://wa.me/${business.whatsapp}?text=Hola! Me interesa el servicio de ${service.name}&utm_source=landing&utm_medium=servicios&utm_campaign=gentsclub`}
               class="service-link" target="_blank" rel="noopener">
              Agendar
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
    <div class="services-note">
      <div class="note-icon">✦</div>
      <p>Todos los servicios incluyen consulta personalizada y productos premium</p>
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 8rem 2rem;
    background: #0a0a0a;
    position: relative;
  }

  .services-section::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 1px; height: 80px;
    background: linear-gradient(180deg, transparent, #d4af37, transparent);
  }

  .services-inner { max-width: 1200px; margin: 0 auto; }
  .services-header { text-align: center; margin-bottom: 5rem; }

  .section-label {
    font-size: 0.7rem; letter-spacing: 0.3em; color: #d4af37;
    text-transform: uppercase; font-weight: 500; margin-bottom: 1rem;
    display: inline-flex; align-items: center; gap: 1rem;
  }

  .section-label::before, .section-label::after {
    content: ''; width: 25px; height: 1px; background: #d4af37;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700; line-height: 1.15; margin-bottom: 1.25rem;
  }

  .accent {
    background: linear-gradient(135deg, #d4af37, #f4e5c3);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    font-size: 1.05rem; color: #B0B0B0; max-width: 550px;
    margin: 0 auto; line-height: 1.7; font-weight: 300;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem; margin-bottom: 4rem;
  }

  .service-card {
    position: relative;
    background: linear-gradient(145deg, #1a1a1a 0%, #121212 100%);
    border: 1px solid rgba(212, 175, 55, 0.2);
    padding: 2.5rem 2rem;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    opacity: 0;
    animation: cardFadeIn 0.6s ease-out forwards;
  }

  @keyframes cardFadeIn {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, #d4af37, transparent);
    opacity: 0; transition: opacity 0.4s;
  }

  .service-card:hover {
    transform: translateY(-8px);
    border-color: rgba(212, 175, 55, 0.35);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(212, 175, 55, 0.15);
  }

  .service-card:hover::before { opacity: 1; }

  .service-number {
    font-family: 'Playfair Display', serif;
    font-size: 4rem; font-weight: 900;
    color: rgba(212, 175, 55, 0.15);
    line-height: 1; margin-bottom: 1.5rem;
  }

  .service-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem; font-weight: 700; margin-bottom: 0.75rem;
  }

  .service-desc {
    font-size: 0.9rem; color: #B0B0B0;
    line-height: 1.6; font-weight: 300; margin-bottom: 2rem;
  }

  .service-bottom {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 1.5rem; border-top: 1px solid rgba(212, 175, 55, 0.12);
  }

  .service-price {
    font-family: 'Playfair Display', serif;
    font-size: 2rem; font-weight: 700; color: #d4af37;
  }

  .currency { font-size: 0.9rem; font-weight: 400; color: #707070; margin-left: 0.25rem; }

  .service-link {
    font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: #d4af37; text-decoration: none; font-weight: 500;
    display: flex; align-items: center; gap: 0.5rem; transition: gap 0.3s;
  }

  .service-link:hover { gap: 0.85rem; }

  .services-note {
    display: flex; align-items: center; justify-content: center; gap: 1rem;
    padding: 2rem;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.05), rgba(212, 175, 55, 0.02));
    border: 1px solid rgba(212, 175, 55, 0.1);
  }

  .note-icon { color: #d4af37; font-size: 1.25rem; }
  .services-note p { font-size: 0.875rem; color: #a8a8a8; font-style: italic; }

  @media (max-width: 768px) {
    .services-section { padding: 5rem 1.5rem; }
    .service-bottom { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .service-link { width: 100%; justify-content: center; }
  }
</style>
