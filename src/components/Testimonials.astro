---
const { testimonials, whatsapp } = Astro.props;

const mapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY ?? '';
const googlePlaceId = import.meta.env.PUBLIC_GOOGLE_PLACE_ID ?? '';
const googleMapsLink = 'https://maps.google.com/?cid=4585858650926838920';

type DisplayTestimonial = {
  name: string;
  rating: number;
  text: string;
  service: string;
  link?: string;
};

const truncate = (text: string, maxLength = 170) => {
  if (!text || text.length <= maxLength) return text;
  return `${text.slice(0, maxLength).trim()}...`;
};

const getReviewText = (review: any) => {
  if (typeof review?.originalText === 'string') return review.originalText;
  if (review?.originalText?.text) return review.originalText.text;
  if (typeof review?.text === 'string') return review.text;
  if (review?.text?.text) return review.text.text;
  return 'Sin texto disponible.';
};

const toSpanishRelativeTime = (value?: string) => {
  if (!value) return 'reciente';

  const normalized = value.toLowerCase().trim();
  const replacements: Array<[RegExp, string]> = [
    [/^a year ago$/, 'hace 1 ano'],
    [/^an hour ago$/, 'hace 1 hora'],
    [/^a day ago$/, 'hace 1 dia'],
    [/^a week ago$/, 'hace 1 semana'],
    [/^a month ago$/, 'hace 1 mes'],
    [/^a minute ago$/, 'hace 1 minuto'],
    [/^(\d+)\s+years?\s+ago$/, 'hace $1 anos'],
    [/^(\d+)\s+months?\s+ago$/, 'hace $1 meses'],
    [/^(\d+)\s+weeks?\s+ago$/, 'hace $1 semanas'],
    [/^(\d+)\s+days?\s+ago$/, 'hace $1 dias'],
    [/^(\d+)\s+hours?\s+ago$/, 'hace $1 horas'],
    [/^(\d+)\s+minutes?\s+ago$/, 'hace $1 minutos']
  ];

  for (const [pattern, replacement] of replacements) {
    if (pattern.test(normalized)) {
      return normalized.replace(pattern, replacement);
    }
  }

  return normalized;
};

let displayTestimonials: DisplayTestimonial[] = testimonials;

if (mapsApiKey && googlePlaceId) {
  try {
    const response = await fetch(
      `https://places.googleapis.com/v1/places/${googlePlaceId}?fields=reviews,googleMapsUri`,
      {
        headers: {
          'X-Goog-Api-Key': mapsApiKey
        }
      }
    );

    if (response.ok) {
      const place = await response.json();
      const reviews = Array.isArray(place.reviews) ? place.reviews : [];
      const positive = reviews
        .filter((review: any) => Number(review.rating || 0) >= 4)
        .slice(0, 3);

      if (positive.length > 0) {
        displayTestimonials = positive.map((review: any) => ({
          name: review.authorAttribution?.displayName || 'Cliente',
          rating: Number(review.rating || 5),
          text: truncate(getReviewText(review)),
          service: review.relativePublishTimeDescription
            ? `Reseña verificada · ${toSpanishRelativeTime(review.relativePublishTimeDescription)}`
            : 'Reseña verificada en Google',
          link: review.googleMapsUri || place.googleMapsUri || googleMapsLink
        }));
      }
    }
  } catch (error) {
    console.error('No se pudieron cargar las reseñas premium de Google:', error);
  }
}
---

<section id="testimonials" class="testimonials-section">
  <div class="testimonials-inner">
    <div class="testimonials-header">
      <div class="section-label">Testimonios</div>
      <h2 class="section-title">Clientes que vuelven <span class="accent">por el resultado</span></h2>
      <p class="section-subtitle">Opiniones breves, directas y sin exagerar.</p>
    </div>
    <div class="testimonials-grid">
      {displayTestimonials.map((t: any) => (
        <div class="testimonial-card google-testimonial-card">
          <div class="testimonial-quote">"</div>
          <div class="testimonial-stars premium-stars">
            {Array.from({ length: t.rating || 5 }, () => null).map(() => (
              <span>&#9733;</span>
            ))}
          </div>
          <p class="testimonial-text">{t.text}</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">{t.name.charAt(0)}</div>
            <div>
              <div class="testimonial-name">{t.name}</div>
              <div class="testimonial-service">{t.service}</div>
            </div>
          </div>
          {t.link && (
            <a href={t.link} target="_blank" rel="noopener" class="testimonial-link">Ver en Google Maps</a>
          )}
        </div>
      ))}
    </div>
    <div class="cta-banner">
      <h3 class="cta-title">Tu próximo corte <span class="accent">empieza aquí</span></h3>
      <p class="cta-text">Escribe por WhatsApp y reserva tu lugar.</p>
      <a href={`https://wa.me/${whatsapp}?text=Hola,%20quiero%20agendar%20una%20cita%20en%20Gent's%20Club.&utm_source=landing&utm_medium=cta&utm_campaign=gentsclub`} class="btn-gold" target="_blank" rel="noopener">Agendar por WhatsApp</a>
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: 8rem 2rem;
    background: #0a0a0a;
    position: relative;
  }

  .testimonials-section::before {
    content: '';
    position: absolute; top: 0; left: 10%; right: 10%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.35), transparent);
  }

  .testimonials-inner { max-width: 1200px; margin: 0 auto; }
  .testimonials-header { text-align: center; margin-bottom: 5rem; }

  .section-label {
    font-size: 0.7rem; letter-spacing: 0.3em; color: #d4af37;
    text-transform: uppercase; font-weight: 500; margin-bottom: 1rem;
    display: inline-flex; align-items: center; gap: 1rem;
  }

  .section-label::before, .section-label::after {
    content: ''; width: 25px; height: 1px; background: #d4af37;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700; line-height: 1.15; margin-bottom: 1.25rem;
  }

  .accent {
    background: linear-gradient(135deg, #d4af37, #f4e5c3);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    font-size: 1.05rem; color: #B0B0B0; max-width: 550px;
    margin: 0 auto; line-height: 1.7; font-weight: 300;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem; margin-bottom: 4rem;
  }

  .testimonial-card {
    background: #151515;
    border: 1px solid rgba(212, 175, 55, 0.12);
    padding: 2.2rem;
    position: relative;
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .testimonial-card:hover {
    border-color: rgba(212, 175, 55, 0.35);
    transform: translateY(-4px);
    box-shadow: 0 26px 60px rgba(0, 0, 0, 0.28);
  }

  .testimonial-quote {
    position: absolute; top: 1.5rem; right: 2rem;
    font-family: 'Playfair Display', serif; font-size: 5rem;
    color: rgba(212, 175, 55, 0.08); line-height: 1;
  }

  .testimonial-stars { display: flex; gap: 0.25rem; margin-bottom: 1.5rem; }
  .testimonial-stars span { color: #d4af37; font-size: 0.85rem; }

  .premium-stars {
    color: #d4af37;
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    text-shadow: 0 0 18px rgba(212, 175, 55, 0.18);
  }

  .testimonial-text {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.02rem;
    line-height: 1.85;
    color: #f0ebe1;
    font-weight: 400;
    margin-bottom: 1.6rem;
    max-width: 32ch;
  }

  .testimonial-author {
    display: flex; align-items: center; gap: 1rem;
    padding-top: 1.25rem; border-top: 1px solid rgba(212, 175, 55, 0.12);
    margin-top: auto;
  }

  .testimonial-avatar {
    width: 48px; height: 48px;
    background: linear-gradient(135deg, #d4af37, #f4e5c3);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif; font-weight: 700;
    font-size: 1.1rem; color: #0a0a0a;
    flex-shrink: 0;
  }

  .testimonial-name { font-weight: 600; font-size: 0.95rem; }
  .testimonial-service {
    font-size: 0.8rem;
    color: #8b877c;
    margin-top: 0.2rem;
    line-height: 1.5;
  }
  .testimonial-link {
    margin-top: 0.9rem;
    color: #d4af37;
    text-decoration: none;
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    align-self: flex-start;
  }
  .testimonial-link:hover { color: #f4e5c3; }

  .google-testimonial-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(212, 175, 55, 0.04), transparent 45%);
    pointer-events: none;
  }

  .google-testimonial-card > * {
    position: relative;
    z-index: 1;
  }

  .cta-banner {
    text-align: center; padding: 4rem 2rem;
    background: #111111;
    border: 1px solid rgba(212, 175, 55, 0.12);
  }

  .cta-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; margin-bottom: 1rem;
  }

  .cta-text { font-size: 1rem; color: #B0B0B0; margin-bottom: 2.5rem; font-weight: 300; }

  .btn-gold {
    display: inline-flex; align-items: center; gap: 0.75rem;
    padding: 1.1rem 2.5rem;
    background: linear-gradient(135deg, #d4af37 0%, #f4e5c3 100%);
    color: #0A0A0A; text-decoration: none;
    font-size: 0.8rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase;
    transition: all 0.4s; box-shadow: 0 4px 25px rgba(212, 175, 55, 0.3);
  }

  .btn-gold:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 40px rgba(212, 175, 55, 0.45);
  }

  @media (max-width: 768px) {
    .testimonials-section { padding: 5rem 1.5rem; }
    .testimonials-grid { grid-template-columns: 1fr; }
    .cta-banner { padding: 3rem 1.5rem; }
    .testimonial-card { padding: 1.8rem; }
    .testimonial-text { max-width: none; }
  }
</style>
