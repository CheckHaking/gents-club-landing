---
import '../styles/global.css';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Gallery from '../components/Gallery.astro';
import Testimonials from '../components/Testimonials.astro';
import BookingFlow from '../components/BookingFlow.astro';
import GooglePresence from '../components/GooglePresence.astro';
import Location from '../components/Location.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { siteContent } from '../data/site';

const { business, about, services, gallery, testimonials, amenities, booking } = siteContent;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={`${business.name} - Barberia premium en ${business.city}. Agenda tu cita por WhatsApp con ${business.owner}.`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Cormorant+Garamond:wght@300;400;600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <meta name="robots" content="index, follow" />
    <meta name="author" content={business.name} />
    <meta name="keywords" content="barberia, peluqueria, corte de cabello, barba, afeitado, Lerdo, Gents Club, Charly" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${business.name} - Barbería y Peluquería Premium`} />
    <meta property="og:description" content="Una barberia enfocada en la atencion directa, agenda por WhatsApp y experiencia premium." />
    <meta property="og:site_name" content={business.name} />

    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href="https://gentsclub-gents-club-landing.eamwzl.easypanel.host/" />

    <title>{business.name} - Barberia Premium en {business.city}</title>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BarberShop",
      "name": business.name,
      "description": `${business.subtitle}. Agenda por WhatsApp con ${business.owner} en ${business.city}.`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address,
        "addressLocality": "Lerdo",
        "addressRegion": "Durango",
        "addressCountry": "MX"
      },
      "telephone": business.phone,
      "openingHours": ["Mo-Sa 11:00-20:00"],
      "sameAs": [business.instagramUrl],
      "priceRange": "$$",
      "foundingDate": business.founded,
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de barberia",
        "itemListElement": services.map((service) => ({
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": service.name,
            "serviceType": service.name
          },
          "price": String(service.price),
          "priceCurrency": "MXN"
        }))
      },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".hero-title", ".hero-tagline", ".hero-description"]
      }
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Donde esta ubicada la barberia Gents Club en Lerdo?",
          "acceptedAnswer": {"@type": "Answer", "text": `${business.name} esta ubicada en ${business.address}. Horario: ${business.weekdays} de ${business.hours}.`}
        },
        {
          "@type": "Question",
          "name": "Cuanto cuesta un corte de cabello en Gents Club?",
          "acceptedAnswer": {"@type": "Answer", "text": "El corte clasico y moderno tiene un precio desde $200 MXN. Los precios finales pueden variar segun el servicio solicitado."}
        },
        {
          "@type": "Question",
          "name": "Cual es el horario de Gents Club Lerdo?",
          "acceptedAnswer": {"@type": "Answer", "text": `Atendemos de ${business.weekdays} en horario de ${business.hours}. Domingos cerrado.`}
        },
        {
          "@type": "Question",
          "name": "Como puedo agendar en Gents Club?",
          "acceptedAnswer": {"@type": "Answer", "text": `Puedes escribir por WhatsApp para revisar horarios disponibles y confirmar tu cita directamente con ${business.owner}.`}
        }
      ]
    })} />

    <style>
      :root {
        --bg-primary: #0A0A0A;
        --bg-secondary: #111111;
        --bg-card: #151515;
        --gold: #D4AF37;
        --gold-light: #F4E5C3;
        --gold-dark: #B8941E;
        --ivory: #FAEBD7;
        --text-primary: #FFFFFF;
        --text-secondary: #B0B0B0;
        --text-muted: #8A8A8A;
        --border: rgba(212, 175, 55, 0.12);
        --border-hover: rgba(212, 175, 55, 0.35);
        --glow: rgba(212, 175, 55, 0.15);
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; scroll-padding-top: 80px; }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
      }

      :focus-visible {
        outline: 2px solid var(--gold);
        outline-offset: 3px;
      }

      body {
        font-family: 'Montserrat', sans-serif;
        background: var(--bg-primary);
        color: var(--text-primary);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .hero-section {
        min-height: 100vh;
        contain: layout style paint;
      }
    </style>
  </head>
  <body>
    <!-- NAV -->
    <nav class="nav">
      <a href="/" class="nav-logo">GENT'S <span>CLUB</span></a>
      <button class="nav-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="primary-nav">
        <span></span><span></span><span></span>
      </button>
      <ul id="primary-nav" class="nav-links">
        <li><a href="#services">Servicios</a></li>
        <li><a href="#about">Sobre Charly</a></li>
        <li><a href="#gallery">Galería</a></li>
        <li><a href="#testimonials">Opiniones</a></li>
        <li><a href="#agendar">Cómo agendar</a></li>
        <li><a href="#location">Ubicación</a></li>
        <li><a href={`https://wa.me/${business.whatsapp}`} class="nav-cta" target="_blank" rel="noopener">Agendar Cita</a></li>
      </ul>
    </nav>
    <script>
      const toggle = document.querySelector('.nav-toggle');
      const links = document.querySelector('.nav-links');
      const setExpanded = (open) => {
        toggle?.setAttribute('aria-expanded', String(open));
        toggle?.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
      };
      toggle?.addEventListener('click', () => {
        const willOpen = !links?.classList.contains('open');
        links?.classList.toggle('open');
        toggle.classList.toggle('active');
        setExpanded(willOpen);
      });
      document.querySelectorAll('.nav-links a').forEach(a => {
        a.addEventListener('click', () => {
          links?.classList.remove('open');
          toggle?.classList.remove('active');
          setExpanded(false);
        });
      });
    </script>

    <main>
      <Hero business={business} />
      <About about={about} business={business} />
      <Services services={services} whatsapp={business.whatsapp} />
      <Gallery gallery={gallery} />
      <Testimonials testimonials={testimonials} whatsapp={business.whatsapp} />
      <BookingFlow booking={booking} whatsapp={business.whatsapp} owner={business.owner} />
      <GooglePresence business={business} amenities={amenities} />
      <Location business={business} />
    </main>

    <WhatsAppButton whatsapp={business.whatsapp} />

    <footer class="footer">
      <div class="footer-content">
        <div class="footer-logo">GENT'S CLUB</div>
        <p class="footer-sub">Barbería clásica en Lerdo &bull; Desde {business.founded}</p>
        <p class="footer-tagline">Citas directas con {business.owner} por WhatsApp.</p>
        {business.instagramUrl && (
          <a class="footer-social" href={business.instagramUrl} target="_blank" rel="noopener" aria-label={`Instagram @${business.instagram}`}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
            <span>@{business.instagram}</span>
          </a>
        )}
        <div class="footer-divider"></div>
        <p class="footer-copy">&copy; {new Date().getFullYear()} {business.name}. Todos los derechos reservados.</p>
      </div>
    </footer>

    <style>
      .nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        padding: 1.25rem 3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(10, 10, 10, 0.88);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
      }

      .nav-logo {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 900;
        letter-spacing: 0.1em;
        color: var(--text-primary);
        text-decoration: none;
      }

      .nav-logo span {
        background: linear-gradient(135deg, var(--gold), var(--gold-light));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .nav-links {
        display: flex;
        gap: 2.5rem;
        list-style: none;
        align-items: center;
      }

      .nav-links a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        transition: color 0.3s;
      }

      .nav-links a:hover { color: var(--gold); }

      .nav-cta {
        padding: 0.6rem 1.5rem !important;
        border: 1px solid var(--gold) !important;
        color: var(--gold) !important;
        transition: all 0.3s !important;
      }

      .nav-cta:hover {
        background: var(--gold) !important;
        color: var(--bg-primary) !important;
      }

      .footer {
        padding: 4rem 2rem 2rem;
        background: var(--bg-primary);
        border-top: 1px solid var(--border);
        text-align: center;
      }

      .footer-content { max-width: 1200px; margin: 0 auto; }

      .footer-logo {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 900;
        letter-spacing: 0.1em;
        background: linear-gradient(135deg, var(--gold), var(--gold-light));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.5rem;
      }

      .footer-sub {
        font-size: 0.75rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 0.5rem;
      }

      .footer-tagline {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1rem;
        color: var(--text-secondary);
        font-style: italic;
      }

      .footer-social {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1rem;
        padding: 0.55rem 1rem;
        border: 1px solid rgba(212, 175, 55, 0.25);
        color: var(--gold);
        text-decoration: none;
        font-size: 0.82rem;
        letter-spacing: 0.05em;
        transition: border-color 0.3s ease, color 0.3s ease;
      }

      .footer-social:hover {
        border-color: var(--gold);
        color: var(--gold-light);
      }

      .footer-divider {
        width: 80px;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
        margin: 2rem auto;
      }

      .footer-copy { font-size: 0.8rem; color: var(--text-muted); }

      .nav-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        flex-direction: column;
        gap: 5px;
      }

      .nav-toggle span {
        display: block;
        width: 24px;
        height: 2px;
        background: var(--gold);
        transition: all 0.3s;
      }

      .nav-toggle.active span:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
      }

      .nav-toggle.active span:nth-child(2) {
        opacity: 0;
      }

      .nav-toggle.active span:nth-child(3) {
        transform: rotate(-45deg) translate(5px, -5px);
      }

      @media (max-width: 768px) {
        .nav { padding: 1rem 1.5rem; }
        .nav-toggle { display: flex; }
        .nav-links {
          display: none;
          position: fixed;
          top: 60px; left: 0; right: 0;
          background: rgba(10, 10, 10, 0.95);
          backdrop-filter: blur(20px);
          flex-direction: column;
          padding: 2rem;
          gap: 1.5rem;
          border-bottom: 1px solid var(--border);
        }
        .nav-links.open { display: flex; }
        .nav-links a { font-size: 1rem; }
        .nav-cta { text-align: center; width: 100%; display: block !important; }
        .footer { padding: 3rem 1.5rem 1.5rem; }
        .footer-logo { font-size: 1.5rem; }
      }
    </style>
  </body>
</html>
