---
import { getBarbers, getBarberBySlug, getGalleryByBarber, getBusinessInfo, getBarberPhotoUrl, getGalleryImageUrl } from '../../lib/directus';

export async function getStaticPaths() {
  const barbers = await getBarbers();
  return barbers.map((b: any) => ({ params: { slug: b.slug } }));
}

const { slug } = Astro.params;
const barber = await getBarberBySlug(slug as string);
const gallery = barber ? await getGalleryByBarber(barber.id) : [];
const business = await getBusinessInfo();

if (!barber) return Astro.redirect('/');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${barber.nickname || barber.name} - Barbero en ${business.name}. ${barber.specialty || ''}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Cormorant+Garamond:wght@300;400;600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>{barber.nickname || barber.name} - {business.name}</title>
    <style>
      :root {
        --bg-primary: #0A0A0A; --bg-secondary: #111111; --bg-card: #151515;
        --gold: #D4AF37; --gold-light: #F4E5C3;
        --text-primary: #FFFFFF; --text-secondary: #B0B0B0; --text-muted: #707070;
        --border: rgba(212, 175, 55, 0.12);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Montserrat', sans-serif;
        background: var(--bg-primary); color: var(--text-primary);
        line-height: 1.6; -webkit-font-smoothing: antialiased; overflow-x: hidden;
      }
    </style>
  </head>
  <body>
    <!-- NAV -->
    <nav class="nav">
      <a href="/" class="nav-logo">GENT'S <span>CLUB</span></a>
      <a href="/" class="nav-back">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Volver
      </a>
    </nav>

    <!-- BARBER HERO -->
    <section class="barber-hero">
      <div class="barber-hero-inner">
        <div class="barber-photo-col">
          <img src={getBarberPhotoUrl(barber.photo)} alt={barber.name} class="barber-main-photo" />
        </div>
        <div class="barber-info-col">
          <div class="barber-badge">BARBERO</div>
          <h1 class="barber-title">{barber.nickname || barber.name}</h1>
          {barber.nickname && <p class="barber-realname">{barber.name}</p>}
          {barber.specialty && <p class="barber-specialty">{barber.specialty}</p>}
          {barber.bio && <p class="barber-bio">{barber.bio}</p>}

          <div class="barber-socials">
            {barber.instagram && (
              <a href={`https://instagram.com/${barber.instagram}`} class="social-btn" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                @{barber.instagram}
              </a>
            )}
            {barber.tiktok && (
              <a href={`https://tiktok.com/@${barber.tiktok}`} class="social-btn" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-.81-.1l-.38.9z"/></svg>
                @{barber.tiktok}
              </a>
            )}
            {barber.facebook && (
              <a href={barber.facebook} class="social-btn" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Facebook
              </a>
            )}
          </div>

          <a href={`https://wa.me/${barber.whatsapp || business.whatsapp}?text=Hola ${barber.nickname || barber.name}! Voy a pasar hoy por un corte, estas en la barberia?&utm_source=landing&utm_medium=barbero&utm_campaign=${barber.slug}`} class="btn-gold" target="_blank" rel="noopener">
            Contactar a {barber.nickname || barber.name}
          </a>
        </div>
      </div>
    </section>

    <!-- GALLERY -->
    {gallery.length > 0 && (
    <section class="barber-gallery">
      <div class="gallery-inner">
        <h2 class="gallery-title">Trabajos de <span class="accent">{barber.nickname || barber.name}</span></h2>
        <div class="gallery-grid">
          {gallery.map((item: any) => (
            <div class="gallery-item">
              <img src={getGalleryImageUrl(item.image)} alt={item.alt || ''} loading="lazy" />
              {item.category && <span class="gallery-tag">{item.category}</span>}
            </div>
          ))}
        </div>
      </div>
    </section>
    )}

    <style>
      .nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        padding: 1.25rem 3rem;
        display: flex; align-items: center; justify-content: space-between;
        background: rgba(10, 10, 10, 0.88); backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
      }
      .nav-logo {
        font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 900;
        letter-spacing: 0.1em; color: var(--text-primary); text-decoration: none;
      }
      .nav-logo span {
        background: linear-gradient(135deg, var(--gold), var(--gold-light));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      }
      .nav-back {
        display: flex; align-items: center; gap: 0.5rem;
        color: var(--gold); text-decoration: none;
        font-size: 0.85rem; font-weight: 500; transition: gap 0.3s;
      }
      .nav-back:hover { gap: 0.75rem; }

      .barber-hero {
        padding: 8rem 2rem 4rem;
        background: var(--bg-primary);
      }
      .barber-hero-inner {
        max-width: 1100px; margin: 0 auto;
        display: grid; grid-template-columns: 400px 1fr; gap: 4rem;
        align-items: center;
      }
      .barber-main-photo {
        width: 100%; aspect-ratio: 3/4;
        object-fit: cover;
        border: 1px solid var(--border);
      }
      .barber-badge {
        font-size: 0.7rem; letter-spacing: 0.3em; color: var(--gold);
        margin-bottom: 1rem;
      }
      .barber-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 900; margin-bottom: 0.5rem;
      }
      .barber-realname { font-size: 1rem; color: var(--text-muted); margin-bottom: 0.5rem; }
      .barber-specialty {
        font-size: 1.1rem; color: var(--gold); margin-bottom: 1.5rem;
        font-style: italic;
      }
      .barber-bio {
        font-size: 1rem; color: var(--text-secondary); line-height: 1.8;
        margin-bottom: 2rem; font-weight: 300;
      }
      .barber-socials {
        display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem;
      }
      .social-btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.6rem 1.25rem;
        background: rgba(212, 175, 55, 0.08);
        border: 1px solid rgba(212, 175, 55, 0.2);
        color: var(--gold); text-decoration: none;
        font-size: 0.85rem; font-weight: 500;
        transition: all 0.3s;
      }
      .social-btn svg { width: 18px; height: 18px; }
      .social-btn:hover {
        background: rgba(212, 175, 55, 0.15);
        border-color: var(--gold);
      }
      .btn-gold {
        display: inline-flex; align-items: center; gap: 0.75rem;
        padding: 1.1rem 2.5rem;
        background: linear-gradient(135deg, var(--gold), var(--gold-light));
        color: var(--bg-primary); text-decoration: none;
        font-size: 0.85rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
        transition: all 0.4s; box-shadow: 0 4px 25px rgba(212, 175, 55, 0.3);
      }
      .btn-gold:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 40px rgba(212, 175, 55, 0.45);
      }

      .barber-gallery { padding: 4rem 2rem 8rem; background: var(--bg-secondary); }
      .gallery-inner { max-width: 1200px; margin: 0 auto; }
      .gallery-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        font-weight: 700; margin-bottom: 3rem; text-align: center;
      }
      .accent {
        background: linear-gradient(135deg, var(--gold), var(--gold-light));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      }
      .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
      }
      .gallery-item {
        position: relative; aspect-ratio: 4/5; overflow: hidden;
        background: var(--bg-card);
      }
      .gallery-item img {
        width: 100%; height: 100%; object-fit: cover;
        transition: transform 0.5s;
      }
      .gallery-item:hover img { transform: scale(1.05); }
      .gallery-tag {
        position: absolute; bottom: 1rem; left: 1rem;
        font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
        color: var(--gold); font-weight: 600;
        background: rgba(0,0,0,0.7); padding: 0.3rem 0.75rem;
        backdrop-filter: blur(8px);
      }

      @media (max-width: 768px) {
        .nav { padding: 1rem 1.5rem; }
        .barber-hero-inner { grid-template-columns: 1fr; gap: 2rem; }
        .barber-main-photo { max-width: 300px; margin: 0 auto; }
        .barber-hero { padding: 6rem 1.5rem 3rem; }
        .barber-info-col { text-align: center; }
        .barber-socials { justify-content: center; }
        .gallery-grid { grid-template-columns: repeat(2, 1fr); }
      }
    </style>
  </body>
</html>
